{
  "name": "aqw-vault",
  "version": "1.0.0",
  "description": "Gestor de cuentas para AQW",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },

  "keywords": [],
  "author": "",
  "license": "ISC",

  "dependencies": {
    "lowdb": "^7.0.1"
  },

  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },

  "build": {
    "appId": "com.aqwvault.app",
    "productName": "AQWVault",

    "win": {
      "icon": "assets/icon.ico",
      "target": ["zip"],
      "forceCodeSigning": false
    },

    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}